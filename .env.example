# =============================================================================
# ClimateIQ — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# =============================================================================

# ---- OpenRouter AI ----------------------------------------------------------
# Get your API key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=your-openrouter-api-key-here

# Model to use via OpenRouter (default: google/gemini-flash-1.5)
# See full model list at: https://openrouter.ai/models
OPENROUTER_MODEL=google/gemini-flash-1.5

# OpenRouter base URL (default is correct — only change for testing)
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ---- Supabase / PostgreSQL --------------------------------------------------
# Your Supabase connection string (found in: Project Settings → Database → Connection string)
# Format: postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres
# For local PostgreSQL: postgresql://user:password@localhost:5432/carbon_platform
SUPABASE_DB_URL=postgresql://postgres:your-password@db.your-project.supabase.co:5432/postgres

# ---- Feature Flags ----------------------------------------------------------
# Set to false for local development without external service credentials.
# All services have safe in-memory fallbacks when disabled.
USE_OPENROUTER=true
USE_SUPABASE=true
USE_ANALYTICS=true
USE_EVENT_QUEUE=true

# ---- Application ------------------------------------------------------------
ENVIRONMENT=production
LOG_LEVEL=INFO
MAX_HISTORY_ENTRIES=20
